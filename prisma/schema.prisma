generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String?  @unique
  passwordHash String?
  facebookId   String?  @unique
  name         String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
}
